{
  "manifest_version": 3,
  "name": "Zuka Sensei Extension",
  "version": "1.0",
  "description": "An AI assistant that sees your screen.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8080/*"
  ]
}